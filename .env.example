# PrintSmith MCP Server Configuration
# ====================================
# Copy this file to .env and edit with your values

# PrintSmith Connection
# ---------------------
# Get these from your PrintSmith administrator
# Example: https://printsmith.yourcompany.com or http://192.168.1.100:8080
PRINTSMITH_BASE_URL=

# API token from PrintSmith Vision (Setup > Preferences > API Settings)
PRINTSMITH_API_TOKEN=

# SSL verification (set to false if using self-signed certs)
PRINTSMITH_VERIFY_SSL=true

# Request timeout in seconds
PRINTSMITH_TIMEOUT=30

# MCP Transport
# -------------
# stdio  = Local Claude Desktop (via config file)
# http   = Remote access via HTTP/SSE (recommended for LXC)
MCP_TRANSPORT=http

# HTTP server settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Development
# -----------
# Set to true to use mock data without PrintSmith connection
# Useful for testing the MCP integration
USE_MOCK_DATA=true
