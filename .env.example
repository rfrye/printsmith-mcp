# PrintSmith MCP Server Configuration
# ====================================
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# PostgreSQL Connection
# ---------------------
# The IP or hostname of your PrintSmith server's PostgreSQL instance.
# PrintSmith Vision runs PostgreSQL on port 5432 by default.
PG_HOST=192.168.1.100

# PostgreSQL port (default 5432)
PG_PORT=5432

# Database name (default is "printsmith" on most installations)
PG_DATABASE=printsmith

# Database user — use a read-only user if possible
PG_USER=postgres

# Database password
PG_PASSWORD=

# Query timeout in seconds
PG_TIMEOUT=30

# MCP Transport
# -------------
# stdio  = Local Claude Desktop (via config file)
# http   = Remote access via HTTP/SSE (recommended for LXC)
MCP_TRANSPORT=http

# HTTP server settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Development
# -----------
# Set to true to use built-in mock data without a real database connection.
# Useful for testing the MCP integration before pointing at PrintSmith.
USE_MOCK_DATA=false
